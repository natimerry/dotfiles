{
    "diff_view_style": "split",
    "active_pane_modifiers": {
        "inactive_opacity": 0.8
    },
    "cli_default_open_behavior": "existing_window",
    "remove_trailing_whitespace_on_save": false,
    "format_on_save": "off",
    "project_panel": {
        "dock": "left"
    },
    "outline_panel": {
        "dock": "left"
    },
    "collaboration_panel": {
        "dock": "left"
    },
    "agent": {
        "dock": "right",
        "favorite_models": [],
        "model_parameters": []
    },
    "git_panel": {
        "dock": "left"
    },
    "session": {
        "trust_all_worktrees": true
    },
    "context_servers": {
        "codebase-memory-mcp": {
            "command": "/home/nat/.local/bin/codebase-memory-mcp",
            "args": [
                ""
            ]
        }
    },
    "agent_servers": {
        "codex-acp": {
            "type": "registry"
        },
        "gemini": {
            "type": "registry"
        },
        "github-copilot-cli": {
            "type": "registry"
        }
    },
    "icon_theme": "Catppuccin Mocha",
    "ui_font_size": 16,
    "buffer_font_size": 15,
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "JetBrains Islands Dark"
    },
    "experimental.theme_overrides": {
            "background.appearance": "blurred",

    "background": "#09090bcc",
    "panel.background": "#00000040",
    "editor.background": "#00000030",
    "terminal.background": "#00000030",
    "toolbar.background": "#00000040",

    "tab_bar.background": "#00000040",
    "tab.inactive_background": "#00000020",
    "tab.active_background": "#3f3f4660",

    "status_bar.background": "#09090bcc",
    "title_bar.background": "#09090bcc",

    "border": "#00000000",
    "border.variant": "#00000000",

    "scrollbar.track.background": "#52525b20",
    "scrollbar.thumb.background": "#52525b40",

    "editor.gutter.background": "#00000000",
    "editor.active_line.background": "#3f3f4640",

    "editor.line_number": "#ffffff70",
    "editor.active_line_number": "#ffffffcc",

    "editor.indent_guide": "#ffffff25",
    "editor.indent_guide_active": "#ffffff70",

    "surface.background": "#18181bff",
    "elevated_surface.background": "#18181bff",
    "editor.document_highlight.bracket_background": "#3f3f46ff",
    "editor.document_highlight.read_background": "#3f3f46ff",
    "editor.document_highlight.write_background": "#3f3f46ff",
  },
  
}
