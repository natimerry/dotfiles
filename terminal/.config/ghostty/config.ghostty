## Ported from ~/.config/alacritty.
## Colors are generated by pywal; rerun wal and reload Ghostty to update them.
theme = /home/nat/.cache/wal/ghostty.conf

window-inherit-working-directory = false
working-directory=/home/nat


## Font -----------------------------------------------------------
font-family = "Adwaita Mono"
font-family-bold = "Adwaita Mono"
font-family-italic = "Adwaita Mono"
font-family-bold-italic = "Adwaita Mono"
font-size = 11

## Window ---------------------------------------------------------
window-width = 140
window-height = 40
window-decoration = false
window-padding-x = 12
window-padding-y = 12
window-padding-balance = true

background-opacity = 0.8
# background-opacity-cells = true

## Scrolling ------------------------------------------------------
scrollback-limit = 10000000
mouse-scroll-multiplier = precision:1,discrete:3

## Selection ------------------------------------------------------
copy-on-select = clipboard

## Cursor ---------------------------------------------------------
cursor-style = block
cursor-style-blink = true
cursor-text = cell-background

## Mouse ----------------------------------------------------------
mouse-hide-while-typing = false
